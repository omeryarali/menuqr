# Copy to .env.local and fill in from your Supabase project:
#   Dashboard -> Project Settings -> API

# Project URL, e.g. https://abcdefghijklm.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" / publishable key. Safe to expose to the browser — it is the key
# RLS is designed around. Never put the service_role key in a NEXT_PUBLIC_ var:
# it bypasses RLS entirely and would hand every tenant's data to any visitor.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Absolute origin of this deployment. Used for QR targets and auth redirects, so
# it must match the real URL or the printed codes point at the wrong host.
# Local: http://localhost:3000    Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
